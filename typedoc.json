{
    "$schema": "https://typedoc.org/schema.json",
    "plugin": [
        "typedoc-plugin-fastly"
    ],
    "theme": "fastly",
    "tsconfig": "tsconfig.json",
    "exclude": [
        "types/index.d.ts"
    ],
    "entryPointStrategy": "expand",
    "entryPoints": [
        "types/*"
    ],
    "excludeExternals": true,
    "externalPattern": [
        "node_modules/**"
    ],
    "excludeInternal": true,
    "excludePrivate": true,
    "categorizeByGroup": false,
    "includeVersion": true,
    "githubPages": false,
    "cleanOutputDir": true,
    "out": "documentation/build",
    "favicon": "https://www.fastly.com/favicons/favicon.svg"
}